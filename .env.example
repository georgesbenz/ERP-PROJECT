# ============================================================
# ROOT ENV (used by docker-compose) — copy to .env and adjust
# Racine (utilisée par docker-compose) — copier en .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=erp
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=erp
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Backend (NestJS) ---
BACKEND_PORT=4000
# DATABASE_URL is built from the values above; keep host = "postgres" (compose service name)
DATABASE_URL=postgresql://erp:change_me_strong_password@postgres:5432/erp?schema=public
REDIS_URL=redis://redis:6379

# JWT secrets — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_with_random_secret
JWT_REFRESH_SECRET=replace_with_another_random_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# --- Frontend (Next.js) ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000

# --- Nginx ---
NGINX_PORT=8080
