generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED

  @@map("user_status")
}

enum InvoiceType {
  SALE
  PURCHASE
  CREDIT_NOTE
  DEBIT_NOTE

  @@map("invoice_type")
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
  VOID

  @@map("invoice_status")
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_MONEY
  CHEQUE
  CREDIT

  @@map("payment_method")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED

  @@map("payment_status")
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  DELIVERED
  CANCELLED
  RETURNED

  @@map("sale_status")
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED

  @@map("purchase_status")
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
  RETURN
  PURCHASE_RECEIPT
  PURCHASE_PARTIAL_RECEIPT
  PURCHASE_RETURN_SUPPLIER
  SALE_DELIVERY
  SALE_PARTIAL_DELIVERY
  CUSTOMER_RETURN_RESALABLE
  CUSTOMER_RETURN_DAMAGED
  POS_SALE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  DAMAGE_WRITE_OFF
  EXPIRY_WRITE_OFF
  STATE_CHANGE
  TRANSFER_OUT
  TRANSFER_IN
  OPENING_STOCK
  CYCLE_COUNT_IN
  CYCLE_COUNT_OUT
  PRODUCTION_IN
  PRODUCTION_OUT
  RESERVATION
  RESERVATION_RELEASE
  BACKORDER_FULFILL

  @@map("movement_type")
}

enum AdjustmentStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  APPLIED

  @@map("adjustment_status")
}

enum TransferStatus {
  DRAFT
  PENDING
  IN_TRANSIT
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED

  @@map("transfer_status")
}

enum StockState {
  AVAILABLE
  RESERVED
  IN_TRANSIT
  DAMAGED
  EXPIRED
  INSPECTION
  ON_HOLD
  SCRAPPED

  @@map("stock_state")
}

enum JournalType {
  GENERAL
  SALES
  PURCHASES
  CASH
  BANK

  @@map("journal_type")
}

enum EntryStatus {
  DRAFT
  POSTED
  CANCELLED

  @@map("entry_status")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE

  @@map("account_type")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST

  @@map("lead_status")
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
  CANCELLED

  @@map("opportunity_status")
}

enum ActivityType {
  EMAIL
  CALL
  MEETING
  TASK
  NOTE

  @@map("activity_type")
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED

  @@map("campaign_status")
}

enum CampaignType {
  EMAIL
  SMS
  SOCIAL_MEDIA
  PUSH_NOTIFICATION

  @@map("campaign_type")
}

enum BudgetStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ACTIVE
  CLOSED

  @@map("budget_status")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED

  @@map("approval_status")
}

enum ForecastType {
  REVENUE
  EXPENSE
  CASH_FLOW

  @@map("forecast_type")
}

enum KpiPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY

  @@map("kpi_period")
}

enum EventSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL

  @@map("event_severity")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED

  @@map("task_status")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT

  @@map("task_priority")
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR

  @@map("notification_type")
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  OVERDUE
  CANCELLED

  @@map("goal_status")
}

// ─── TENANT / AUTH ────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  email     String?
  phone     String?
  address   String?
  city      String?
  country   String?
  currency  String   @default("USD")
  locale    String   @default("en")
  timezone  String   @default("UTC")
  logoUrl   String?
  isActive  Boolean  @default(true)
  plan      String   @default("starter")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches           Branch[]
  users              User[]
  roles              Role[]
  products           Product[]
  categories         Category[]
  suppliers          Supplier[]
  customers          Customer[]
  warehouses         Warehouse[]
  inventories        Inventory[]
  inventoryMovements InventoryMovement[]
  sales              Sale[]
  purchases          Purchase[]
  invoices           Invoice[]
  payments           Payment[]
  taxes              Tax[]
  accounts           Account[]
  journals           Journal[]
  leads              Lead[]
  opportunities      Opportunity[]
  pipelines          Pipeline[]
  campaigns          Campaign[]
  meetings           Meeting[]
  calls              Call[]
  tasks              Task[]
  notes              Note[]
  budgetPlans        BudgetPlan[]
  budgetCategories   BudgetCategory[]
  forecasts          Forecast[]
  costCenters        CostCenter[]
  departments        Department[]
  kpiTrackers        KpiTracker[]
  financialAnalytics FinancialAnalytic[]
  revenueAnalytics   RevenueAnalytic[]
  expenseAnalytics   ExpenseAnalytic[]
  cashFlowForecasts  CashFlowForecast[]
  goalTrackers       GoalTracker[]
  approvalWorkflows  ApprovalWorkflow[]
  settings           Setting[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  activityLogs       ActivityLog[]
  eventLogs          EventLog[]
  stockAdjustments   StockAdjustment[]
  warehouseTransfers WarehouseTransfer[]
  stockReservations  StockReservation[]
  stockBatches       StockBatch[]
  serialNumbers      SerialNumber[]
  priceLists         PriceList[]
  backorders         Backorder[]
  cycleCounts        CycleCount[]

  @@map("tenants")
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  code      String
  address   String?
  city      String?
  country   String?
  phone     String?
  email     String?
  isMain    Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles  UserRole[]
  sales      Sale[]
  purchases  Purchase[]
  warehouses Warehouse[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("branches")
}

model User {
  id            String     @id @default(uuid())
  tenantId      String
  email         String
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  avatarUrl     String?
  status        UserStatus @default(ACTIVE)
  lastLoginAt   DateTime?
  emailVerified Boolean    @default(false)
  refreshToken  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles            UserRole[]
  userPermissions  UserPermission[]
  salesCreated     Sale[]           @relation("SaleCreatedBy")
  purchasesCreated Purchase[]      @relation("PurchaseCreatedBy")
  auditLogs       AuditLog[]
  activityLogs    ActivityLog[]
  notifications   Notification[]
  tasksAssigned   Task[]           @relation("TaskAssignee")
  tasksCreated    Task[]           @relation("TaskCreatedBy")
  meetingsCreated Meeting[]
  callsCreated    Call[]
  notes           Note[]
  crmActivities   CrmActivity[]
  budgetApprovals BudgetApproval[]
  approvalSteps   ApprovalStep[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  module      String
  action      String
  description String?

  roles            RolePermission[]
  userPermissions  UserPermission[]

  @@unique([module, action])
  @@map("permissions")
}

model UserPermission {
  userId       String
  permissionId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@index([userId])
  @@map("user_permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     String
  roleId     String
  branchId   String?
  assignedAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ─── CATALOG ──────────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  slug      String
  parentId  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")
  products Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("categories")
}

model Product {
  id            String    @id @default(uuid())
  tenantId      String
  categoryId    String?
  name          String
  sku           String
  barcode       String?
  description   String?
  unitOfMeasure String    @default("pcs")
  costPrice     Decimal   @db.Decimal(15, 4)
  salePrice     Decimal   @db.Decimal(15, 4)
  minStock      Decimal   @db.Decimal(15, 4) @default(0)
  maxStock      Decimal?  @db.Decimal(15, 4)
  isService     Boolean   @default(false)
  isActive      Boolean   @default(true)
  taxId         String?
  imageUrl      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  trackSerials    Boolean  @default(false)
  trackBatches    Boolean  @default(false)
  hasExpiry       Boolean  @default(false)
  reorderPoint    Decimal? @db.Decimal(15, 4)
  safetyStock     Decimal? @db.Decimal(15, 4)
  alertQty        Decimal? @db.Decimal(15, 4)
  valuationMethod String   @default("WEIGHTED_AVG")

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        Category?           @relation(fields: [categoryId], references: [id])
  tax             Tax?                @relation(fields: [taxId], references: [id])
  inventories     Inventory[]
  movements       InventoryMovement[]
  saleLines       SaleLine[]
  purchaseLines   PurchaseLine[]
  stockBatches    StockBatch[]
  serialNumbers   SerialNumber[]
  reservations    StockReservation[]
  backorders      Backorder[]
  priceListItems  PriceListItem[]
  adjustmentLines StockAdjustmentLine[]
  transferLines   TransferLine[]
  cycleCountLines CycleCountLine[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@map("products")
}

// ─── PARTNERS ─────────────────────────────────────────────────────────────────

model Supplier {
  id           String    @id @default(uuid())
  tenantId     String
  name         String
  code         String
  email        String?
  phone        String?
  address      String?
  city         String?
  country      String?
  taxNumber    String?
  website      String?
  creditLimit  Decimal?  @db.Decimal(15, 2)
  paymentTerms Int?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases Purchase[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("suppliers")
}

model Customer {
  id            String    @id @default(uuid())
  tenantId      String
  name          String
  code          String
  email         String?
  phone         String?
  address       String?
  city          String?
  country       String?
  taxNumber     String?
  creditLimit   Decimal?  @db.Decimal(15, 2)
  paymentTerms  Int?
  loyaltyPoints Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales         Sale[]
  invoices      Invoice[]
  leads         Lead[]
  opportunities Opportunity[]
  campaigns     CampaignContact[]
  notes         Note[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("customers")
}

// ─── INVENTORY ────────────────────────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String?
  name      String
  code      String
  address   String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch?             @relation(fields: [branchId], references: [id])
  inventories   Inventory[]
  movements     InventoryMovement[]
  transfersFrom WarehouseTransfer[] @relation("TransferFrom")
  transfersTo   WarehouseTransfer[] @relation("TransferTo")
  adjustments   StockAdjustment[]
  reservations  StockReservation[]
  batches       StockBatch[]
  cycleCounts   CycleCount[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("warehouses")
}

model Inventory {
  id            String  @id @default(uuid())
  tenantId      String
  productId     String
  warehouseId   String
  quantity      Decimal @db.Decimal(15, 4) @default(0)
  reservedQty   Decimal @db.Decimal(15, 4) @default(0)
  damagedQty    Decimal @db.Decimal(15, 4) @default(0)
  expiredQty    Decimal @db.Decimal(15, 4) @default(0)
  inTransitQty  Decimal @db.Decimal(15, 4) @default(0)
  inspectionQty Decimal @db.Decimal(15, 4) @default(0)
  onHoldQty     Decimal @db.Decimal(15, 4) @default(0)
  updatedAt     DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@index([tenantId])
  @@index([productId])
  @@map("inventory")
}

model InventoryMovement {
  id             String       @id @default(uuid())
  tenantId       String
  productId      String
  warehouseId    String
  type           MovementType
  quantity       Decimal      @db.Decimal(15, 4)
  unitCost       Decimal?     @db.Decimal(15, 4)
  reference      String?
  notes          String?
  createdBy      String?
  createdAt      DateTime     @default(now())
  fromState      String?
  toState        String?
  reason         String?
  referenceType  String?
  warehouseToId  String?
  approvalStatus String       @default("AUTO")
  approvedBy     String?
  approvedAt     DateTime?
  batchId        String?
  serialId       String?

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([tenantId])
  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
  @@map("inventory_movements")
}

// ─── SALES ────────────────────────────────────────────────────────────────────

model Sale {
  id             String     @id @default(uuid())
  tenantId       String
  branchId       String?
  customerId     String?
  reference      String
  status         SaleStatus @default(DRAFT)
  saleDate       DateTime   @default(now())
  dueDate        DateTime?
  subtotal       Decimal    @db.Decimal(15, 2)
  taxAmount      Decimal    @db.Decimal(15, 2) @default(0)
  discountAmount Decimal    @db.Decimal(15, 2) @default(0)
  total          Decimal    @db.Decimal(15, 2)
  paidAmount     Decimal    @db.Decimal(15, 2) @default(0)
  notes          String?
  createdBy      String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch?    @relation(fields: [branchId], references: [id])
  customer Customer?  @relation(fields: [customerId], references: [id])
  creator  User?      @relation("SaleCreatedBy", fields: [createdBy], references: [id])
  lines    SaleLine[]
  invoices Invoice[]
  payments Payment[]

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
  @@index([tenantId, saleDate])
  @@map("sales")
}

model SaleLine {
  id          String  @id @default(uuid())
  saleId      String
  productId   String
  description String?
  quantity    Decimal @db.Decimal(15, 4)
  unitPrice   Decimal @db.Decimal(15, 4)
  discount    Decimal @db.Decimal(5, 2) @default(0)
  taxRate     Decimal @db.Decimal(5, 2) @default(0)
  total       Decimal @db.Decimal(15, 2)
  sortOrder   Int     @default(0)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@map("sale_lines")
}

// ─── PURCHASES ────────────────────────────────────────────────────────────────

model Purchase {
  id             String         @id @default(uuid())
  tenantId       String
  branchId       String?
  supplierId     String?
  reference      String
  status         PurchaseStatus @default(DRAFT)
  orderDate      DateTime       @default(now())
  expectedDate   DateTime?
  receivedDate   DateTime?
  subtotal       Decimal        @db.Decimal(15, 2)
  taxAmount      Decimal        @db.Decimal(15, 2) @default(0)
  discountAmount Decimal        @db.Decimal(15, 2) @default(0)
  total          Decimal        @db.Decimal(15, 2)
  paidAmount     Decimal        @db.Decimal(15, 2) @default(0)
  notes          String?
  createdBy      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch?        @relation(fields: [branchId], references: [id])
  supplier Supplier?      @relation(fields: [supplierId], references: [id])
  creator  User?          @relation("PurchaseCreatedBy", fields: [createdBy], references: [id])
  lines    PurchaseLine[]
  invoices Invoice[]
  payments Payment[]

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([tenantId, supplierId])
  @@index([tenantId, status])
  @@map("purchases")
}

model PurchaseLine {
  id          String  @id @default(uuid())
  purchaseId  String
  productId   String
  description String?
  quantity    Decimal @db.Decimal(15, 4)
  unitCost    Decimal @db.Decimal(15, 4)
  receivedQty Decimal @db.Decimal(15, 4) @default(0)
  discount    Decimal @db.Decimal(5, 2) @default(0)
  taxRate     Decimal @db.Decimal(5, 2) @default(0)
  total       Decimal @db.Decimal(15, 2)
  sortOrder   Int     @default(0)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@map("purchase_lines")
}

// ─── FINANCE ──────────────────────────────────────────────────────────────────

model Tax {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  code        String
  rate        Decimal  @db.Decimal(5, 2)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("taxes")
}

model Invoice {
  id         String        @id @default(uuid())
  tenantId   String
  type       InvoiceType
  status     InvoiceStatus @default(DRAFT)
  reference  String
  saleId     String?
  purchaseId String?
  customerId String?
  issueDate  DateTime      @default(now())
  dueDate    DateTime?
  subtotal   Decimal       @db.Decimal(15, 2)
  taxAmount  Decimal       @db.Decimal(15, 2) @default(0)
  total      Decimal       @db.Decimal(15, 2)
  paidAmount Decimal       @db.Decimal(15, 2) @default(0)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale     Sale?     @relation(fields: [saleId], references: [id])
  purchase Purchase? @relation(fields: [purchaseId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  payments Payment[]

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@map("invoices")
}

model Payment {
  id           String        @id @default(uuid())
  tenantId     String
  reference    String
  method       PaymentMethod
  status       PaymentStatus @default(PENDING)
  amount       Decimal       @db.Decimal(15, 2)
  currency     String        @default("USD")
  exchangeRate Decimal       @db.Decimal(10, 6) @default(1)
  saleId       String?
  purchaseId   String?
  invoiceId    String?
  notes        String?
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale     Sale?     @relation(fields: [saleId], references: [id])
  purchase Purchase? @relation(fields: [purchaseId], references: [id])
  invoice  Invoice?  @relation(fields: [invoiceId], references: [id])

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("payments")
}

model Account {
  id          String      @id @default(uuid())
  tenantId    String
  code        String
  name        String
  type        AccountType
  parentId    String?
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      Account?           @relation("AccountChildren", fields: [parentId], references: [id])
  children    Account[]          @relation("AccountChildren")
  debitLines  JournalEntryLine[] @relation("DebitAccount")
  creditLines JournalEntryLine[] @relation("CreditAccount")

