  requestedQty Decimal @db.Decimal(15, 4)
  sentQty      Decimal @db.Decimal(15, 4) @default(0)
  receivedQty  Decimal @db.Decimal(15, 4) @default(0)
  unitCost     Decimal @db.Decimal(15, 4) @default(0)
  notes        String?
  sortOrder    Int     @default(0)

  transfer WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product           @relation(fields: [productId], references: [id])

  @@index([transferId])
  @@map("transfer_lines")
}

model StockReservation {
  id          String    @id @default(uuid())
  tenantId    String
  productId   String
  warehouseId String
  saleId      String?
  quantity    Decimal   @db.Decimal(15, 4)
  status      String    @default("ACTIVE")
  expiresAt   DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([tenantId])
  @@index([tenantId, productId, warehouseId])
  @@map("stock_reservations")
}

model StockBatch {
  id           String    @id @default(uuid())
  tenantId     String
  productId    String
  warehouseId  String
  batchNumber  String
  lotNumber    String?
  expiryDate   DateTime?
  quantity     Decimal   @db.Decimal(15, 4)
  costPrice    Decimal   @db.Decimal(15, 4) @default(0)
  state        String    @default("AVAILABLE")
  receivedDate DateTime  @default(now())
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([tenantId, productId, batchNumber])
  @@index([tenantId])
  @@index([tenantId, productId])
  @@map("stock_batches")
}

model SerialNumber {
  id          String   @id @default(uuid())
  tenantId    String
  productId   String
  warehouseId String?
  serial      String
  state       String   @default("AVAILABLE")
  purchaseRef String?
  saleRef     String?
  batchId     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([tenantId, productId, serial])
  @@index([tenantId])
  @@map("serial_numbers")
}

model PriceList {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  code      String
  currency  String    @default("XAF")
  isDefault Boolean   @default(false)
  startDate DateTime?
  endDate   DateTime?
  discount  Decimal   @db.Decimal(5, 2) @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  PriceListItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("price_lists")
}

model PriceListItem {
  id          String   @id @default(uuid())
  priceListId String
  productId   String
  price       Decimal  @db.Decimal(15, 4)
  minQty      Decimal  @db.Decimal(15, 4) @default(1)
  maxQty      Decimal? @db.Decimal(15, 4)

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@index([priceListId])
  @@index([productId])
  @@map("price_list_items")
}

model Backorder {
  id           String    @id @default(uuid())
  tenantId     String
  saleId       String
  productId    String
  warehouseId  String?
  orderedQty   Decimal   @db.Decimal(15, 4)
  deliveredQty Decimal   @db.Decimal(15, 4) @default(0)
  pendingQty   Decimal   @db.Decimal(15, 4)
  status       String    @default("PENDING")
  expectedDate DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([tenantId, saleId])
  @@map("backorders")
}

model CycleCount {
  id          String    @id @default(uuid())
  tenantId    String
  warehouseId String
  reference   String
  status      String    @default("DRAFT")
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?
  createdBy   String?
  approvedBy  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  lines     CycleCountLine[]

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@map("cycle_counts")
}

model CycleCountLine {
  id           String   @id @default(uuid())
  cycleCountId String
  productId    String
  systemQty    Decimal  @db.Decimal(15, 4)
  countedQty   Decimal? @db.Decimal(15, 4)
  variance     Decimal? @db.Decimal(15, 4)
  notes        String?

  cycleCount CycleCount @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@index([cycleCountId])
  @@map("cycle_count_lines")
}
