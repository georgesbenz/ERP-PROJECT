  @@index([tenantId])
  @@map("budget_categories")
}

model BudgetAllocation {
  id           String   @id @default(uuid())
  budgetPlanId String
  categoryId   String
  period       String
  allocated    Decimal  @db.Decimal(15, 2)
  actual       Decimal  @db.Decimal(15, 2) @default(0)
  variance     Decimal  @db.Decimal(15, 2) @default(0)
  notes        String?
  updatedAt    DateTime @updatedAt

  budgetPlan BudgetPlan     @relation(fields: [budgetPlanId], references: [id], onDelete: Cascade)
  category   BudgetCategory @relation(fields: [categoryId], references: [id])

  @@unique([budgetPlanId, categoryId, period])
  @@index([budgetPlanId])
  @@map("budget_allocations")
}

model BudgetApproval {
  id           String         @id @default(uuid())
  budgetPlanId String
  approverId   String?
  status       ApprovalStatus @default(PENDING)
  comments     String?
