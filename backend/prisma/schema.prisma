  reason       String?
  changedBy    String?
  snapshot     Json
  createdAt    DateTime @default(now())

  budgetPlan BudgetPlan @relation(fields: [budgetPlanId], references: [id], onDelete: Cascade)

  @@index([budgetPlanId])
  @@map("budget_revisions")
}

