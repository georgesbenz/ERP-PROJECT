# Backend env — copy to backend/.env for running outside Docker.
# When using docker-compose, the root .env is injected instead.

NODE_ENV=development
PORT=4000

# Use localhost when running on the host; "postgres"/"redis" inside Docker.
DATABASE_URL=postgresql://erp:erp@localhost:5432/erp?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace_with_random_secret
JWT_REFRESH_SECRET=replace_with_another_random_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

CORS_ORIGIN=http://localhost:3000
